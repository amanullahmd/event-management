{
  "compilerOptions": {
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "types": ["jest", "node", "@testing-library/jest-dom"],
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@/modules/*": [
        "./src/modules/*"
      ],
      "@/modules/authentication/*": [
        "./src/modules/authentication/*"
      ],
      "@/modules/event-management/*": [
        "./src/modules/event-management/*"
      ],
      "@/modules/ticket-management/*": [
        "./src/modules/ticket-management/*"
      ],
      "@/modules/payment-processing/*": [
        "./src/modules/payment-processing/*"
      ],
      "@/modules/email-campaigns/*": [
        "./src/modules/email-campaigns/*"
      ],
      "@/modules/analytics/*": [
        "./src/modules/analytics/*"
      ],
      "@/modules/trust-and-safety/*": [
        "./src/modules/trust-and-safety/*"
      ],
      "@/modules/compliance/*": [
        "./src/modules/compliance/*"
      ],
      "@/modules/high-availability/*": [
        "./src/modules/high-availability/*"
      ],
      "@/modules/shared-common/*": [
        "./src/modules/shared-common/*"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    "**/*.mts",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    ".next"
  ]
}
